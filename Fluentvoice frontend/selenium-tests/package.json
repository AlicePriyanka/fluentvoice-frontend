{
  "name": "fluentvoice-selenium-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js Selenium end-to-end and quality test suite for FluentVoice",
  "type": "commonjs",
  "scripts": {
    "test": "node run.js",
    "test:headed": "node run.js --headed",
    "test:smoke": "node run.js --suite=smoke",
    "test:full": "node run.js --suite=full",
    "test:chrome": "node run.js --browsers=chrome",
    "test:compatibility": "node run.js --suite=compatibility"
  },
  "dependencies": {
    "axe-core": "^4.10.3",
    "exceljs": "^4.4.0",
    "selenium-webdriver": "^4.34.0"
  }
}
